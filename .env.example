# Cardano network to target: "mainnet" | "preprod" | "preview"
VITE_CARDANO_NETWORK=preprod

# Blockfrost project ID for the SAME network as above.
# Create one for free at https://blockfrost.io
VITE_BLOCKFROST_PROJECT_ID=

# Optional: base URL of the Lucky ADA backend service (see ./server).
# Enables gift titles/messages, the puzzle hint, and the recipients list.
# Leave empty to run purely on-chain (gift code carries the hint as a fallback).
VITE_API_BASE_URL=
