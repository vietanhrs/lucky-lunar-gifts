# Port to listen on
PORT=8787

# SQLite database file (use :memory: for an ephemeral DB)
DATABASE_PATH=./data/lucky-ada.db

# Allowed CORS origin (the web client's URL), or * for any
CORS_ORIGIN=*

# Cardano network: mainnet | preprod | preview
CARDANO_NETWORK=preprod

# Blockfrost project ID for the SAME network. REQUIRED — the service verifies
# every gift and claim on-chain. Create one for free at https://blockfrost.io
BLOCKFROST_PROJECT_ID=
